rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Relaxed for development, ideally check request.auth.token.email_verified == true
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "daiperes2012@gmail.com" && request.auth.token.email_verified == true;
    }

    match /test/connection {
      allow read: if true;
    }

    // 1. User Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // 2. Video Rules
    match /videos/{videoId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (isAdmin() || existing().creatorId == request.auth.uid);

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      }
    }

    // 3. Chat Rules
    match /chats/{chatId} {
      function isValidChat(data) {
        return data.participants is list && data.participants.size() >= 1 && data.participants.size() <= 10;
      }
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in existing().participants);
      allow create: if isSignedIn() && 
        isValidChat(incoming()) &&
        request.auth.uid in incoming().participants &&
        incoming().updatedAt == request.time;
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid in existing().participants && incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt']))
      );
      
      match /messages/{messageId} {
        function canAccessChat() {
          return isAdmin() || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
        function isValidMessage(data) {
          return data.chatId == chatId &&
                 data.senderId == request.auth.uid &&
                 data.text is string && data.text.size() <= 5000;
        }
        allow get: if isSignedIn() && canAccessChat();
        allow list: if isSignedIn() && canAccessChat();
        allow create: if isSignedIn() && 
          isValidMessage(incoming()) &&
          canAccessChat() &&
          incoming().createdAt == request.time;
      }
    }

    // 4. Match Rules
    match /matches/{matchId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // 5. Lives Rules
    match /lives/{liveId} {
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (isAdmin() || existing().creatorId == request.auth.uid);
    }

    // 6. Likes Rules
    match /likes/{likeId} {
      allow list, get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // 7. Collection Group Rule for Notifications (Hardened)
    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && 
                   (isAdmin() || resource.data.participants.hasAny([request.auth.uid]));
      allow get: if isSignedIn() && 
                   (isAdmin() || resource.data.participants.hasAny([request.auth.uid]));
    }
  }
}
