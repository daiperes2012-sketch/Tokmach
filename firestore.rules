rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // In production, mandate email_verified == true
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "daiperes2012@gmail.com" && request.auth.token.email_verified == true;
    }

    // Helper for strict key validation during creation
    function hasOnlyKeys(keys, count) {
      return keys.hasAll(keys) && keys.size() == count;
    }

    match /test/connection {
      allow read: if true;
    }

    // 1. User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() <= 100 &&
               data.photoURL is string && data.photoURL.size() <= 1000 &&
               data.uid == userId;
      }
      
      // Restricted read: Only the owner or an admin can read full profile. 
      // If public data is needed, use a sub-collection "public" per Pillar 6.
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || existing().isPublic == true);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'isPublic', 'updatedAt']);
      allow delete: if isAdmin(); // Users usually shouldn't delete profiles in this app without request
    }

    // 2. Video Rules
    match /videos/{videoId} {
      function isValidVideo(data) {
        return data.creatorId == request.auth.uid &&
               data.videoUrl is string && data.videoUrl.size() <= 2000 &&
               data.description is string && data.description.size() <= 500 &&
               (data.type == 'video' || data.type == 'photo' || data.type == 'live');
      }

      allow read: if true; // Public feed
      allow create: if isSignedIn() && isValidVideo(incoming()) && isValidId(videoId);
      
      // updates: only stats increments (from anyone) or metadata (only owner)
      allow update: if isSignedIn() && (
        // Action: Owner updates metadata
        (existing().creatorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'updatedAt'])) ||
        // Action: Anyone increments likesCount/commentsCount (limited to these stats)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount']) && 
         incoming().likesCount is int && incoming().commentsCount is int) ||
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (isAdmin() || existing().creatorId == request.auth.uid);

      match /comments/{commentId} {
        function isValidComment(data) {
          return data.userId == request.auth.uid &&
                 data.text is string && data.text.size() <= 1000 &&
                 data.videoId == videoId;
        }
        allow list: if true;
        allow get: if true;
        allow create: if isSignedIn() && isValidComment(incoming()) && isValidId(commentId);
        allow update, delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
      }
    }

    // 3. Chat Rules
    match /chats/{chatId} {
      function isParticipant() {
        return request.auth.uid in existing().participants;
      }
      
      function isValidChat(data) {
        return data.participants is list && data.participants.size() >= 1 && data.participants.size() <= 10;
      }
      
      allow read: if isSignedIn() && (isAdmin() || isParticipant());
      allow create: if isSignedIn() && 
        isValidChat(incoming()) &&
        request.auth.uid in incoming().participants &&
        incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isParticipant() && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']))
      );
      
      match /messages/{messageId} {
        function canAccessChat() {
          return isAdmin() || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
        function isValidMessage(data) {
          return data.chatId == chatId &&
                 data.senderId == request.auth.uid &&
                 data.text is string && data.text.size() <= 5000;
        }
        allow get, list: if isSignedIn() && canAccessChat();
        allow create: if isSignedIn() && 
          isValidMessage(incoming()) &&
          canAccessChat() &&
          incoming().createdAt == request.time;
      }
    }

    // 4. Match Rules
    match /matches/{matchId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(matchId);
      allow update: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // 5. Lives Rules
    match /lives/{liveId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() || 
        existing().creatorId == request.auth.uid ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['viewersCount', 'updatedAt']))
      );
      allow delete: if isSignedIn() && (isAdmin() || existing().creatorId == request.auth.uid);
    }

    // 6. Likes Rules
    match /likes/{likeId} {
      // Secure list query
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(likeId);
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // 7. Collection Group Rule for Notifications (Hardened)
    match /{path=**}/messages/{messageId} {
      allow list: if isSignedIn() && 
                   (isAdmin() || resource.data.participants.hasAny([request.auth.uid]));
      allow get: if isSignedIn() && 
                   (isAdmin() || resource.data.participants.hasAny([request.auth.uid]));
    }
  }
}
